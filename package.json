{
  "name": "modular-game-store",
  "private": true,
  "scripts": {
    "dev": "concurrently -n store,cart,reviews -c blue,green,yellow \"pnpm --filter @mgs/store dev\" \"pnpm --filter @mgs/cart dev\" \"pnpm --filter @mgs/reviews dev\"",
    "build": "pnpm -r build",
    "build:store": "pnpm --filter @mgs/store build",
    "build:cart": "pnpm --filter @mgs/cart build",
    "build:reviews": "pnpm --filter @mgs/reviews build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "pnpm -r exec rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "2.1.9",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8",
    "zephyr-webpack-plugin": "^0.1.13"
  }
}
